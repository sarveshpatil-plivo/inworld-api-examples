# Inworld API key (from https://platform.inworld.ai/api-keys) — needs TTS access
INWORLD_API_KEY=

# Deepgram API key (STT) — https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Google Gemini API key (LLM) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Public base URL of this server (your ngrok HTTPS URL, no trailing slash)
PUBLIC_URL=https://your-domain.ngrok-free.app

# Plivo credentials (from https://console.plivo.com/dashboard/)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Plivo phone number to auto-map to this app, in E.164 (e.g. +14155551234)
PLIVO_PHONE_NUMBER=

# Optional
# SERVER_PORT=3000
# DEFAULT_COUNTRY_CODE=1
# SYSTEM_PROMPT="...override inbound/system_prompt.md..."
# DEEPGRAM_MODEL=nova-2-phonecall
# GEMINI_MODEL=gemini-2.0-flash
# INWORLD_TTS_MODEL=inworld-tts-2
# INWORLD_VOICE=Sarah
# TTS_SAMPLE_RATE=8000           # PCM rate requested from Inworld TTS (resampled to 8k)
