# Inworld API key (from https://platform.inworld.ai/api-keys) — needs STT access
INWORLD_API_KEY=

# Google Gemini API key (LLM) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ElevenLabs API key (TTS) — https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Public base URL of this server (your ngrok HTTPS URL, no trailing slash)
PUBLIC_URL=https://your-domain.ngrok-free.app

# Plivo credentials (from https://console.plivo.com/dashboard/)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Plivo phone number to auto-map to this app, in E.164 (e.g. +14155551234)
PLIVO_PHONE_NUMBER=

# Optional
# SERVER_PORT=3000
# DEFAULT_COUNTRY_CODE=1
# SYSTEM_PROMPT="...override inbound/system_prompt.md..."
# INWORLD_STT_MODEL=inworld/inworld-stt-1
# GEMINI_MODEL=gemini-2.0-flash
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL=eleven_flash_v2_5
