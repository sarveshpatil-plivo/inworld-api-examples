# Inworld API key (from https://platform.inworld.ai/api-keys) — needs STT + Router + TTS scopes
INWORLD_API_KEY=

# Public base URL of this server (your ngrok HTTPS URL, no trailing slash)
PUBLIC_URL=https://your-domain.ngrok-free.app

# Plivo credentials (from https://console.plivo.com/dashboard/)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Plivo phone number to auto-map to this app, in E.164 (e.g. +14155551234)
PLIVO_PHONE_NUMBER=

# Optional
# SERVER_PORT=3000
# DEFAULT_COUNTRY_CODE=1
# SYSTEM_PROMPT="...override inbound/system_prompt.md..."
# INWORLD_MODEL=openai/gpt-4.1-mini          # Router/LLM model
# INWORLD_STT_MODEL=inworld/inworld-stt-1     # STT model
# INWORLD_TTS_MODEL=inworld-tts-2             # TTS model
# INWORLD_VOICE=Sarah                         # TTS voice
# TTS_SAMPLE_RATE=8000                        # PCM rate requested from TTS (resampled to 8k)
