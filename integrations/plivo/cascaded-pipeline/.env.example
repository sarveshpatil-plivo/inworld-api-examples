# Inworld API key (from https://platform.inworld.ai/api-keys)
INWORLD_API_KEY=

# Your public server URL (e.g., https://your-domain.ngrok-free.app)
SERVER_URL=

# Plivo credentials (from https://console.plivo.com/dashboard/)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Optional: customize the voice assistant
# SYSTEM_PROMPT="You are a helpful voice assistant powered by Inworld."
# PORT=3000

# Optional: TTS configuration
# TTS_VOICE=Sarah
# TTS_MODEL=inworld-tts-2

# Optional: LLM configuration
# INWORLD_MODEL=openai/gpt-4.1-mini
