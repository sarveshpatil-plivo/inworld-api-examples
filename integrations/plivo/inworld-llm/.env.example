# Inworld API key (from https://platform.inworld.ai/api-keys) — needs Router/LLM access
INWORLD_API_KEY=

# Deepgram API key (STT) — https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ElevenLabs API key (TTS) — https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Public base URL of this server (your ngrok HTTPS URL, no trailing slash)
PUBLIC_URL=https://your-domain.ngrok-free.app

# Plivo credentials (from https://console.plivo.com/dashboard/)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Plivo phone number to auto-map to this app, in E.164 (e.g. +14155551234)
PLIVO_PHONE_NUMBER=

# Optional
# SERVER_PORT=3000
# DEFAULT_COUNTRY_CODE=1
# SYSTEM_PROMPT="...override inbound/system_prompt.md..."
# INWORLD_MODEL=openai/gpt-4.1-mini          # Inworld Router/LLM model
# DEEPGRAM_MODEL=nova-2-phonecall            # Deepgram STT model
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # ElevenLabs voice
# ELEVENLABS_MODEL=eleven_flash_v2_5         # ElevenLabs model
