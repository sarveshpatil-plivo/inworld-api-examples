# Inworld API key (from https://platform.inworld.ai/api-keys) — needs Realtime API scope
INWORLD_API_KEY=

# Public base URL of this server (your ngrok HTTPS URL, no trailing slash)
PUBLIC_URL=https://your-domain.ngrok-free.app

# Plivo credentials (from https://console.plivo.com/dashboard/)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Plivo phone number to auto-map to this app, in E.164 (e.g. +14155551234)
PLIVO_PHONE_NUMBER=

# Optional
# SERVER_PORT=3000
# DEFAULT_COUNTRY_CODE=1
# SYSTEM_PROMPT="...override inbound/system_prompt.md..."
# INWORLD_MODEL=openai/gpt-4.1-mini
# INWORLD_VOICE=Sarah
# INWORLD_TTS_MODEL=inworld-tts-2
# INWORLD_STT_MODEL=assemblyai/universal-streaming-multilingual
